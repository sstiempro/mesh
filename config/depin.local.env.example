# Copy to config/depin.local.env and fill in YOUR OWN app credentials.
# config/depin.local.env is GITIGNORED — it never enters version control, and the agent never reads it.
# Leave any app blank to skip it. These are DePIN ACCOUNT logins (not wallet seeds) — still yours alone.

# Honeygain — sign up at https://honeygain.com  (official Docker image; x86, runs emulated on Apple Silicon)
HONEYGAIN_EMAIL=
HONEYGAIN_PASS=

# EarnApp — sign up at https://earnapp.com, then get your node UUID:
#   register a device → the dashboard gives a link like https://earnapp.com/r/sdk-node-<UUID>; use the UUID part.
EARNAPP_UUID=

# Pawns.app (IPRoyal) — sign up at https://pawns.app  (official arm64 CLI)
PAWNS_EMAIL=
PAWNS_PASS=
